{
  "name": "05 Re-engagement + Renewal",
  "nodes": [
    {
      "id": "schedule-daily-check",
      "name": "Schedule: Daily 10 AM",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [100, 300],
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "0 10 * * *" }]
        }
      }
    },
    {
      "id": "get-inactive-users",
      "name": "Get Inactive Users (48+ hours)",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [300, 200],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT u.id, u.name, u.whatsapp_number, u.whatsapp_opted_in, j.id AS journey_id, j.current_affirmation_day FROM users u JOIN journeys j ON j.user_id = u.id LEFT JOIN daily_sessions ds ON ds.journey_id = j.id AND ds.affirmation_day_number = j.current_affirmation_day WHERE j.status = 'active' AND j.current_affirmation_day < 21 AND (ds.created_at IS NULL OR ds.created_at < NOW() - INTERVAL '48 hours') AND NOT EXISTS (SELECT 1 FROM notification_log nl WHERE nl.user_id = u.id AND nl.template_name = 're_engagement' AND nl.sent_at > NOW() - INTERVAL '48 hours') AND u.whatsapp_opted_in = true LIMIT 500"
      }
    },
    {
      "id": "get-day21-completions",
      "name": "Get Day 21 Completions (last 2 hours)",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [300, 420],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT u.id, u.name, u.whatsapp_number, u.whatsapp_opted_in, j.id AS journey_id, j.transformation_score, j.tier, j.current_calendar_day, a.earned_at AS perfect_badge_earned FROM users u JOIN journeys j ON j.user_id = u.id LEFT JOIN achievements a ON a.journey_id = j.id AND a.badge_type = 'perfect_consistency' WHERE j.status = 'completed' AND j.completed_at > NOW() - INTERVAL '2 hours' AND NOT EXISTS (SELECT 1 FROM notification_log nl WHERE nl.user_id = u.id AND nl.template_name = 'renewal_prompt' AND nl.sent_at > NOW() - INTERVAL '24 hours')"
      }
    },
    {
      "id": "split-inactive",
      "name": "Split Inactive Users",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [500, 200],
      "parameters": { "batchSize": 1, "options": {} }
    },
    {
      "id": "split-renewals",
      "name": "Split Day 21 Completions",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [500, 420],
      "parameters": { "batchSize": 1, "options": {} }
    },
    {
      "id": "send-reengagement",
      "name": "Send Re-engagement Message",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [700, 200],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.WHATSAPP_API_URL }}/api/v1/sendTemplateMessage",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "json",
        "body": {
          "mode": "raw",
          "rawBody": "={{ JSON.stringify({ phone_number: $json.whatsapp_number, template_name: 're_engagement', broadcast_name: 're_engagement', parameters: [ { name: 'user_name', value: $json.name }, { name: 'day_number', value: String($json.current_affirmation_day) }, { name: 'deep_link', value: 'https://yourapp.com/journey/day/' + $json.current_affirmation_day } ] }) }}"
        }
      }
    },
    {
      "id": "log-reengagement",
      "name": "Log Re-engagement",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [900, 200],
      "parameters": {
        "operation": "insert",
        "table": { "schema": "public", "table": "notification_log" },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "user_id": "={{ $('split-inactive').item.json.id }}",
            "journey_id": "={{ $('split-inactive').item.json.journey_id }}",
            "channel": "whatsapp",
            "template_name": "re_engagement",
            "status": "sent"
          }
        }
      }
    },
    {
      "id": "send-renewal-prompt",
      "name": "Send Renewal Prompt",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [700, 420],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.WHATSAPP_API_URL }}/api/v1/sendTemplateMessage",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "json",
        "body": {
          "mode": "raw",
          "rawBody": "={{ JSON.stringify({ phone_number: $json.whatsapp_number, template_name: 'renewal_prompt', broadcast_name: 'renewal_prompt', parameters: [ { name: 'user_name', value: $json.name }, { name: 'score', value: String(Math.round($json.transformation_score)) }, { name: 'renewal_link', value: 'https://yourapp.com/renew?journey=' + $json.journey_id } ] }) }}"
        }
      }
    },
    {
      "id": "log-renewal",
      "name": "Log Renewal Prompt",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [900, 420],
      "parameters": {
        "operation": "insert",
        "table": { "schema": "public", "table": "notification_log" },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "user_id": "={{ $('split-renewals').item.json.id }}",
            "journey_id": "={{ $('split-renewals').item.json.journey_id }}",
            "channel": "whatsapp",
            "template_name": "renewal_prompt",
            "status": "sent"
          }
        }
      }
    }
  ],
  "connections": {
    "Schedule: Daily 10 AM": {
      "main": [[
        { "node": "Get Inactive Users (48+ hours)", "type": "main", "index": 0 },
        { "node": "Get Day 21 Completions (last 2 hours)", "type": "main", "index": 0 }
      ]]
    },
    "Get Inactive Users (48+ hours)": { "main": [[{ "node": "Split Inactive Users", "type": "main", "index": 0 }]] },
    "Get Day 21 Completions (last 2 hours)": { "main": [[{ "node": "Split Day 21 Completions", "type": "main", "index": 0 }]] },
    "Split Inactive Users": { "main": [[{ "node": "Send Re-engagement Message", "type": "main", "index": 0 }]] },
    "Split Day 21 Completions": { "main": [[{ "node": "Send Renewal Prompt", "type": "main", "index": 0 }]] },
    "Send Re-engagement Message": { "main": [[{ "node": "Log Re-engagement", "type": "main", "index": 0 }]] },
    "Send Renewal Prompt": { "main": [[{ "node": "Log Renewal Prompt", "type": "main", "index": 0 }]] }
  },
  "active": true,
  "settings": { "executionOrder": "v1" }
}
