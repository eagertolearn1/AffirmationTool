# ── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/identity_platform

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change-me-minimum-32-chars-random-string
JWT_REFRESH_SECRET=change-me-different-minimum-32-chars-string
JWT_ACCESS_TTL=900          # 15 minutes in seconds
JWT_REFRESH_TTL=2592000     # 30 days in seconds

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourapp.com
EMAIL_FROM_NAME=Identity Platform

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# ── ElevenLabs ───────────────────────────────────────────────
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID_HI=pNInz6obpgDQGcFmaJgB   # Hindi default voice
ELEVENLABS_VOICE_ID_EN=21m00Tcm4TlvDq8ikWAM   # English default voice

# ── Sarvam AI ────────────────────────────────────────────────
SARVAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SARVAM_API_URL=https://api.sarvam.ai/text-to-speech

# ── Bannerbear ───────────────────────────────────────────────
BANNERBEAR_API_KEY=bb_pr_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
BANNERBEAR_INFOGRAPHIC_TEMPLATE=template_uid_here
BANNERBEAR_PROGRESS_CARD_TEMPLATE=template_uid_here
BANNERBEAR_BADGE_TEMPLATE=template_uid_here

# ── Cloudflare R2 ────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=identity-platform-media
R2_PUBLIC_URL=https://media.yourapp.com    # optional CDN URL

# ── Razorpay ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── WhatsApp (Interakt/WATI) ─────────────────────────────────
WHATSAPP_API_URL=https://api.interakt.ai
WHATSAPP_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=xxxxxxxxxxxxxxxxx
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# ── Firebase FCM ─────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── n8n / Internal Webhooks ──────────────────────────────────
N8N_WEBHOOK_SECRET=change-me-random-string
FRONTEND_URL=http://localhost:3000

# ── Admin ────────────────────────────────────────────────────
ADMIN_EMAILS=admin@yourapp.com
