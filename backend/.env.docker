# ── Use this when running inside Docker (service hostnames, not localhost) ──
# Copy to .env and fill in real API keys before running `make up`

NODE_ENV=development
PORT=3001

# ── Database (Docker service name: postgres) ──────────────────
DATABASE_URL=postgresql://appuser:apppassword@postgres:5432/identity_platform

# ── Redis (Docker service name: redis) ───────────────────────
REDIS_URL=redis://redis:6379

# ── JWT (generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))") ──
JWT_SECRET=CHANGE_ME_min32chars_random
JWT_REFRESH_SECRET=CHANGE_ME_different_min32chars

# ── Email ─────────────────────────────────────────────────────
RESEND_API_KEY=re_YOUR_KEY
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Affirmation Journey

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-YOUR_KEY
OPENAI_MODEL=gpt-4o

# ── ElevenLabs ────────────────────────────────────────────────
ELEVENLABS_API_KEY=sk_b013f66716f8d640e06d6bd41acb84a7f9b4c80c09c39a0f
ELEVENLABS_VOICE_ID_HI=pNInz6obpgDQGcFmaJgB
ELEVENLABS_VOICE_ID_EN=21m00Tcm4TlvDq8ikWAM

# ── Sarvam AI ─────────────────────────────────────────────────
SARVAM_API_KEY=YOUR_KEY
SARVAM_API_URL=https://api.sarvam.ai/text-to-speech

# ── Bannerbear ────────────────────────────────────────────────
BANNERBEAR_API_KEY=bb_pr_YOUR_KEY
BANNERBEAR_INFOGRAPHIC_TEMPLATE=TEMPLATE_UID
BANNERBEAR_PROGRESS_CARD_TEMPLATE=TEMPLATE_UID
BANNERBEAR_BADGE_TEMPLATE=TEMPLATE_UID

# ── Cloudflare R2 ─────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=YOUR_ACCOUNT_ID
R2_ACCESS_KEY_ID=YOUR_ACCESS_KEY
R2_SECRET_ACCESS_KEY=YOUR_SECRET_KEY
R2_BUCKET_NAME=affirmation-media

# ── Razorpay (use test keys for dev) ─────────────────────────
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY
RAZORPAY_KEY_SECRET=YOUR_SECRET
RAZORPAY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# ── WhatsApp ──────────────────────────────────────────────────
WHATSAPP_API_URL=https://api.interakt.ai
WHATSAPP_API_TOKEN=YOUR_TOKEN
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
WHATSAPP_VERIFY_TOKEN=your-verify-token

# ── Firebase FCM ──────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"YOUR_PROJECT"}

# ── n8n Webhooks (Docker: n8n is on port 5678) ───────────────
N8N_WEBHOOK_SECRET=CHANGE_ME_random_string
N8N_WEBHOOK_URL_JOURNEY_READY=http://n8n:5678/webhook/journey-ready
N8N_WEBHOOK_URL_DAY_COMPLETE=http://n8n:5678/webhook/day-complete
N8N_WEBHOOK_URL_PAYMENT_CONFIRMED=http://n8n:5678/webhook/payment-confirmed

# ── Frontend / CORS ───────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Admin ─────────────────────────────────────────────────────
ADMIN_EMAILS=your@email.com
