# ── Use this when running inside Docker (service hostnames, not localhost) ──
# Copy to .env and fill in real API keys before running `make up`

NODE_ENV=development
PORT=3001

# ── Database (Docker service name: postgres) ──────────────────
DATABASE_URL=postgresql://appuser:apppassword@postgres:5432/identity_platform

# ── Redis (Docker service name: redis) ───────────────────────
REDIS_URL=redis://redis:6379

# ── JWT (generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))") ──
JWT_SECRET=CHANGE_ME_min32chars_random
JWT_REFRESH_SECRET=CHANGE_ME_different_min32chars

